{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "chzzk@solitude0429.local",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "name": "CHZZK",
  "description": "Personal Firefox extension that redirects CHZZK HLS playlist quality to the highest NAVER-provided target.",
  "version": "0.4.0",
  "permissions": ["declarativeNetRequest", "storage", "webRequest"],
  "host_permissions": [
    "*://*.akamaized.net/*",
    "*://*.navercdn.com/*",
    "*://*.pstatic.net/*",
    "*://chzzk.naver.com/live/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "32": "icon.png"
  },
  "action": {
    "default_icon": {
      "32": "icon.png"
    },
    "default_popup": "diagnostics.html",
    "default_title": "CHZZK"
  }
}
