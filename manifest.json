{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "chzzk@solitude0429.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "140.0",
      "update_url": "https://chzzk-updates.alpha-apple.dedyn.io/updates.json"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "name": "CHZZK",
  "version": "0.0.23",
  "permissions": [
    "https://*.akamaized.net/*",
    "https://*.chzzk.naver.com/live/*",
    "https://*.gscdn.net/*",
    "https://*.navercdn.com/*",
    "https://*.pstatic.net/*",
    "storage",
    "webRequest",
    "webRequestBlocking"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "icons": {
    "32": "icon-32.png",
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon.png"
  },
  "browser_action": {
    "default_icon": {
      "32": "icon-32.png",
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon.png"
    },
    "default_popup": "diagnostics.html",
    "default_title": "CHZZK"
  },
  "content_scripts": [
    {
      "js": [
        "site-observer.js"
      ],
      "matches": [
        "https://*.chzzk.naver.com/live/*"
      ],
      "run_at": "document_start"
    }
  ]
}
