{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "chzzk@solitude0429.local",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "140.0",
      "update_url": "https://solitude0429.github.io/CHZZK/updates.json"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "name": "CHZZK",
  "description": "Personal Firefox extension that installs tab-scoped session redirects for trusted CHZZK HLS quality requests.",
  "version": "0.0.2",
  "permissions": ["declarativeNetRequest", "storage", "webRequest"],
  "host_permissions": [
    "*://*.akamaized.net/*",
    "*://*.navercdn.com/*",
    "*://*.pstatic.net/*",
    "*://chzzk.naver.com/live/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "32": "icon.png"
  },
  "action": {
    "default_icon": {
      "32": "icon.png"
    },
    "default_popup": "diagnostics.html",
    "default_title": "CHZZK"
  }
}
